# SolarMRV 环境变量配置模板
# 使用方法：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 填入真实值（.env 已被 .gitignore 排除，不会上传公开仓库）
#   3. 在运行系统前 source .env 或使用 python-dotenv 自动加载

# ============================================================
# 硬件与监控参数
# ============================================================
SOLAR_PORT=/dev/tty.usbmodem59810539351   # 光伏控制器串口路径

# ============================================================
# Telegram 告警（如不需要可留空）
# ============================================================
TELEGRAM_BOT_TOKEN=                       # @BotFather 生成
TELEGRAM_CHAT_ID=                         # 你的 Telegram Chat ID

# ============================================================
# 国密 SM2 密钥对（生产环境务必通过本变量注入，不要写在代码默认值里）
# 生成方式：使用 gmssl 库或 OpenSSL 国密分支生成 64 字节私钥 / 128 字节公钥
# ============================================================
SM2_PRIVATE_KEY=                          # 64 字符 hex
SM2_PUBLIC_KEY=                           # 128 字符 hex

# ============================================================
# 联盟链节点
# ============================================================
CHAIN_HOST=1.12.43.152                    # FISCO-BCOS 节点 IP
CHAIN_USER=ubuntu                         # SSH 用户名
CHAIN_CONTRACT=0x075d963d8567395f024da3edce3d63bd2f5f4be3   # SolarDataStore 合约地址

# ============================================================
# 项目后续扩展（占位）
# ============================================================
# EMISSION_RECORD_CONTRACT=                # 待部署：减排量电子记录合约地址
# CCER_METHODOLOGY_VERSION=                # 待配置：CCER 方法学版本号
# GRID_REGION=                             # 待配置：电网区域代号（华东/华南等）
